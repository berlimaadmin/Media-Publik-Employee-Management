<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Data Pegawai - Media Publik</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
    background:#f8f9fc;
}

.header{
    background:#224abe;
    color:white;
    padding:15px 25px;
}

.card{
    border:none;
}

.table th{
    background:#224abe;
    color:white;
}
</style>

</head>
<body>

<div class="header">
    <h3>👥 Data Pegawai - Media Publik</h3>
</div>

<div class="container mt-4">

    <!-- FORM INPUT -->

    <div class="card shadow mb-4">

        <div class="card-header">
            Tambah Pegawai
        </div>

        <div class="card-body">

            <form id="pegawaiForm">

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label>Nama Pegawai</label>
                        <input type="text" id="nama" class="form-control" required>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Jabatan</label>
                        <input type="text" id="jabatan" class="form-control" required>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Email</label>
                        <input type="email" id="email" class="form-control">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>No HP</label>
                        <input type="text" id="no_hp" class="form-control">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Status</label>

                        <select id="status" class="form-select">

                            <option value="Aktif">
                                Aktif
                            </option>

                            <option value="Non Aktif">
                                Non Aktif
                            </option>

                        </select>

                    </div>

                </div>

                <button class="btn btn-primary">
                    Simpan Data
                </button>

            </form>

        </div>

    </div>

    <!-- SEARCH -->

    <div class="card shadow mb-4">

        <div class="card-body">

            <input
                type="text"
                id="searchInput"
                class="form-control"
                placeholder="Cari nama pegawai..."
            >

        </div>

    </div>

    <!-- TABEL -->

    <div class="card shadow">

        <div class="card-header">
            Data Pegawai
        </div>

        <div class="card-body">

            <table class="table table-bordered table-hover">

                <thead>

                <tr>
                    <th>ID</th>
                    <th>Nama</th>
                    <th>Jabatan</th>
                    <th>Email</th>
                    <th>No HP</th>
                    <th>Status</th>
                    <th>Aksi</th>
                </tr>

                </thead>

                <tbody id="pegawaiTable">
                </tbody>

            </table>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<script>

const supabaseUrl = "YOUR_SUPABASE_URL";
const supabaseKey = "YOUR_SUPABASE_ANON_KEY";

const supabase = window.supabase.createClient(
    supabaseUrl,
    supabaseKey
);

const form = document.getElementById("pegawaiForm");
const table = document.getElementById("pegawaiTable");

form.addEventListener("submit", async function(e){

    e.preventDefault();

    const nama = document.getElementById("nama").value;
    const jabatan = document.getElementById("jabatan").value;
    const email = document.getElementById("email").value;
    const no_hp = document.getElementById("no_hp").value;
    const status = document.getElementById("status").value;

    const { error } = await supabase
        .from("employees")
        .insert([
            {
                nama,
                jabatan,
                email,
                no_hp,
                status
            }
        ]);

    if(error){
        alert(error.message);
        return;
    }

    alert("Data berhasil disimpan");

    form.reset();

    loadData();
});

async function loadData(){

    const { data, error } = await supabase
        .from("employees")
        .select("*")
        .order("id");

    if(error){
        console.log(error);
        return;
    }

    renderTable(data);
}

function renderTable(data){

    table.innerHTML = "";

    data.forEach(item => {

        table.innerHTML += `
        <tr>

            <td>${item.id}</td>
            <td>${item.nama}</td>
            <td>${item.jabatan}</td>
            <td>${item.email || ''}</td>
            <td>${item.no_hp || ''}</td>
            <td>${item.status}</td>

            <td>

                <button
                    class="btn btn-danger btn-sm"
                    onclick="hapusData(${item.id})"
                >
                    Hapus
                </button>

            </td>

        </tr>
        `;
    });
}

async function hapusData(id){

    if(!confirm("Hapus data ini?")){
        return;
    }

    const { error } = await supabase
        .from("employees")
        .delete()
        .eq("id", id);

    if(error){
        alert(error.message);
        return;
    }

    loadData();
}

document.getElementById("searchInput")
.addEventListener("keyup", async function(){

    const keyword = this.value;

    const { data } = await supabase
        .from("employees")
        .select("*")
        .ilike("nama", `%${keyword}%`);

    renderTable(data || []);
});

loadData();

</script>
